{
  "permissions": {
    "allow": [
      "mcp__chrome-devtools__wait_for",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__get_network_request",
      "mcp__plugin_vercel_vercel__get_project",
      "mcp__plugin_vercel_vercel__get_deployment",
      "mcp__plugin_vercel_vercel__get_runtime_logs",
      "mcp__plugin_vercel_vercel__list_deployments",
      "mcp__brave__brave_web_search",
      "mcp__firecrawl__firecrawl_search",
      "Bash(git fetch *)",
      "Bash(nslookup *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop.js\""
          }
        ]
      }
    ]
  }
}
