-- =================================================================================
-- Phase 3: Enhanced Team Features - Time-Based Access Control
-- Migration: 006_phase3_time_based_access.sql
-- =================================================================================
-- This migration adds time-based access control with expiration dates
-- and enhanced audit trail functionality

-- =================================================================================
-- Item 14: Add Time-Based Access Control with Expiration Dates
-- =================================================================================

-- Add expiration columns to existing resource_permissions table
ALTER TABLE resource_permissions 
ADD COLUMN expires_at timestamp with time zone,
ADD COLUMN auto_revoke_enabled boolean DEFAULT false NOT NULL,
ADD COLUMN revoked_at timestamp with time zone,
ADD COLUMN revoked_by uuid REFERENCES auth.users(id),
ADD COLUMN revoke_reason text;

-- Add expiration columns to team_invitations (enhance existing)
ALTER TABLE team_invitations
ADD COLUMN auto_revoke_after_days integer DEFAULT 90,
ADD COLUMN revoked_at timestamp with time zone,
ADD COLUMN revoked_by uuid REFERENCES auth.users(id);

-- Create access request table for self-service requests
CREATE TABLE access_requests (
    id uuid DEFAULT gen_random_uuid() PRIMARY KEY,
    requester_id uuid REFERENCES auth.users(id) ON DELETE CASCADE NOT NULL,
    resource_type resource_type NOT NULL,
    resource_id uuid NOT NULL,
    requested_permission permission_level DEFAULT 'view_only' NOT NULL,
    justification text,
    requested_duration_days integer, -- NULL = permanent
    status text DEFAULT 'pending' NOT NULL, -- pending, approved, denied, expired
    reviewed_by uuid REFERENCES auth.users(id),
    reviewed_at timestamp with time zone,
    review_notes text,
    expires_at timestamp with time zone,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    updated_at timestamp with time zone DEFAULT now() NOT NULL,
    CONSTRAINT valid_status CHECK (status IN ('pending', 'approved', 'denied', 'expired', 'withdrawn'))
);

-- Create permission templates for bulk operations
CREATE TABLE permission_templates (
    id uuid DEFAULT gen_random_uuid() PRIMARY KEY,
    created_by uuid REFERENCES auth.users(id) ON DELETE CASCADE NOT NULL,
    team_id uuid REFERENCES teams(id) ON DELETE CASCADE,
    name text NOT NULL,
    description text,
    template_permissions jsonb NOT NULL, -- Array of {resource_type, permission_level, duration_days}
    is_active boolean DEFAULT true NOT NULL,
    usage_count integer DEFAULT 0 NOT NULL,
    last_used_at timestamp with time zone,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    updated_at timestamp with time zone DEFAULT now() NOT NULL
);

-- Enhanced audit log for team activities (extends existing change_history)
CREATE TABLE team_activity_log (
    id uuid DEFAULT gen_random_uuid() PRIMARY KEY,
    team_id uuid REFERENCES teams(id) ON DELETE CASCADE NOT NULL,
    actor_id uuid REFERENCES auth.users(id) ON DELETE CASCADE NOT NULL,
    action_type text NOT NULL, -- permission_granted, permission_revoked, access_requested, etc
    target_user_id uuid REFERENCES auth.users(id),
    resource_type resource_type,
    resource_id uuid,
    permission_level permission_level,
    duration_days integer,
    metadata jsonb DEFAULT '{}' NOT NULL,
    ip_address inet,
    user_agent text,
    created_at timestamp with time zone DEFAULT now() NOT NULL
);

-- =================================================================================
-- Indexes for Performance
-- =================================================================================

-- Access control indexes
CREATE INDEX idx_resource_permissions_expires_at ON resource_permissions(expires_at) WHERE expires_at IS NOT NULL;
CREATE INDEX idx_resource_permissions_auto_revoke ON resource_permissions(auto_revoke_enabled, expires_at) WHERE auto_revoke_enabled = true;
CREATE INDEX idx_access_requests_status ON access_requests(status, created_at);
CREATE INDEX idx_access_requests_requester ON access_requests(requester_id, status);
CREATE INDEX idx_permission_templates_team ON permission_templates(team_id, is_active);
CREATE INDEX idx_team_activity_log_team_time ON team_activity_log(team_id, created_at);
CREATE INDEX idx_team_activity_log_actor ON team_activity_log(actor_id, created_at);

-- =================================================================================
-- Row Level Security
-- =================================================================================

ALTER TABLE access_requests ENABLE ROW LEVEL SECURITY;
ALTER TABLE permission_templates ENABLE ROW LEVEL SECURITY;
ALTER TABLE team_activity_log ENABLE ROW LEVEL SECURITY;

-- Access requests - users can see their own requests and team managers can see team requests
CREATE POLICY "Users can view own access requests" ON access_requests FOR SELECT USING (
    requester_id = auth.uid() OR
    EXISTS (
        SELECT 1 FROM user_profiles up
        WHERE up.user_id = auth.uid() 
        AND up.role IN ('team_manager', 'enterprise_manager', 'admin', 'super_admin')
        AND EXISTS (
            SELECT 1 FROM user_profiles requester_profile
            WHERE requester_profile.user_id = access_requests.requester_id
            AND requester_profile.team_id = up.team_id
        )
    )
);

CREATE POLICY "Users can create access requests" ON access_requests FOR INSERT WITH CHECK (requester_id = auth.uid());

CREATE POLICY "Team managers can update access requests" ON access_requests FOR UPDATE USING (
    EXISTS (
        SELECT 1 FROM user_profiles up
        WHERE up.user_id = auth.uid() 
        AND up.role IN ('team_manager', 'enterprise_manager', 'admin', 'super_admin')
        AND EXISTS (
            SELECT 1 FROM user_profiles requester_profile
            WHERE requester_profile.user_id = access_requests.requester_id
            AND requester_profile.team_id = up.team_id
        )
    )
);

-- Permission templates - team scoped
CREATE POLICY "Permission templates team access" ON permission_templates FOR ALL USING (
    team_id IN (
        SELECT team_id FROM user_profiles 
        WHERE user_id = auth.uid() AND team_id IS NOT NULL
    ) OR
    created_by = auth.uid()
);

-- Team activity log - team members can view
CREATE POLICY "Team activity log access" ON team_activity_log FOR SELECT USING (
    team_id IN (
        SELECT team_id FROM user_profiles 
        WHERE user_id = auth.uid() AND team_id IS NOT NULL
    )
);

CREATE POLICY "Team activity log insert" ON team_activity_log FOR INSERT WITH CHECK (
    actor_id = auth.uid() AND
    team_id IN (
        SELECT team_id FROM user_profiles 
        WHERE user_id = auth.uid() AND team_id IS NOT NULL
    )
);

-- =================================================================================
-- Functions for Access Control Management
-- =================================================================================

-- Function to automatically revoke expired permissions
CREATE OR REPLACE FUNCTION revoke_expired_permissions()
RETURNS void AS $$
BEGIN
    -- Update expired permissions
    UPDATE resource_permissions
    SET 
        revoked_at = now(),
        revoked_by = NULL -- System revocation
    WHERE 
        expires_at IS NOT NULL 
        AND expires_at < now() 
        AND revoked_at IS NULL
        AND auto_revoke_enabled = true;
        
    -- Log the revocations in team activity log
    INSERT INTO team_activity_log (team_id, actor_id, action_type, target_user_id, resource_type, resource_id, permission_level, metadata)
    SELECT DISTINCT
        up.team_id,
        '00000000-0000-0000-0000-000000000000'::uuid, -- System user
        'permission_auto_revoked',
        rp.user_id,
        rp.resource_type,
        rp.resource_id,
        rp.permission_level,
        jsonb_build_object('expired_at', rp.expires_at, 'revoked_at', rp.revoked_at)
    FROM resource_permissions rp
    JOIN user_profiles up ON up.user_id = rp.user_id
    WHERE rp.revoked_at IS NOT NULL 
    AND rp.expires_at IS NOT NULL 
    AND rp.expires_at < now()
    AND up.team_id IS NOT NULL;
END;
$$ LANGUAGE plpgsql;

-- Function to approve access request and grant permission
CREATE OR REPLACE FUNCTION approve_access_request(request_id uuid, reviewer_user_id uuid, review_notes_text text DEFAULT NULL)
RETURNS void AS $$
DECLARE
    request_record access_requests;
    expires_date timestamp with time zone;
BEGIN
    -- Get the request details
    SELECT * INTO request_record FROM access_requests WHERE id = request_id;
    
    IF NOT FOUND THEN
        RAISE EXCEPTION 'Access request not found';
    END IF;
    
    IF request_record.status != 'pending' THEN
        RAISE EXCEPTION 'Request is not in pending status';
    END IF;
    
    -- Calculate expiration date
    IF request_record.requested_duration_days IS NOT NULL THEN
        expires_date := now() + (request_record.requested_duration_days || ' days')::interval;
    END IF;
    
    -- Grant the permission
    INSERT INTO resource_permissions (
        resource_type, resource_id, user_id, permission_level, 
        granted_by, auto_granted, expires_at, auto_revoke_enabled
    ) VALUES (
        request_record.resource_type, 
        request_record.resource_id, 
        request_record.requester_id, 
        request_record.requested_permission,
        reviewer_user_id,
        false,
        expires_date,
        expires_date IS NOT NULL
    )
    ON CONFLICT (resource_type, resource_id, user_id) 
    DO UPDATE SET
        permission_level = EXCLUDED.permission_level,
        granted_by = EXCLUDED.granted_by,
        expires_at = EXCLUDED.expires_at,
        auto_revoke_enabled = EXCLUDED.auto_revoke_enabled,
        revoked_at = NULL,
        revoked_by = NULL;
    
    -- Update the request status
    UPDATE access_requests 
    SET 
        status = 'approved',
        reviewed_by = reviewer_user_id,
        reviewed_at = now(),
        review_notes = review_notes_text,
        updated_at = now()
    WHERE id = request_id;
    
    -- Log the approval
    INSERT INTO team_activity_log (team_id, actor_id, action_type, target_user_id, resource_type, resource_id, permission_level, metadata)
    SELECT 
        up.team_id,
        reviewer_user_id,
        'access_request_approved',
        request_record.requester_id,
        request_record.resource_type,
        request_record.resource_id,
        request_record.requested_permission,
        jsonb_build_object(
            'request_id', request_id,
            'duration_days', request_record.requested_duration_days,
            'expires_at', expires_date,
            'justification', request_record.justification
        )
    FROM user_profiles up
    WHERE up.user_id = request_record.requester_id
    AND up.team_id IS NOT NULL;
END;
$$ LANGUAGE plpgsql;

-- Function to apply permission template to user
CREATE OR REPLACE FUNCTION apply_permission_template(template_id uuid, target_user_id uuid, applied_by_user_id uuid)
RETURNS void AS $$
DECLARE
    template_record permission_templates;
    permission_config jsonb;
    expires_date timestamp with time zone;
BEGIN
    -- Get template
    SELECT * INTO template_record FROM permission_templates WHERE id = template_id AND is_active = true;
    
    IF NOT FOUND THEN
        RAISE EXCEPTION 'Permission template not found or inactive';
    END IF;
    
    -- Apply each permission in the template
    FOR permission_config IN SELECT * FROM jsonb_array_elements(template_record.template_permissions)
    LOOP
        -- Calculate expiration
        IF (permission_config->>'duration_days') IS NOT NULL THEN
            expires_date := now() + ((permission_config->>'duration_days') || ' days')::interval;
        ELSE
            expires_date := NULL;
        END IF;
        
        -- Grant permission
        INSERT INTO resource_permissions (
            resource_type, resource_id, user_id, permission_level, 
            granted_by, auto_granted, expires_at, auto_revoke_enabled
        ) VALUES (
            (permission_config->>'resource_type')::resource_type,
            (permission_config->>'resource_id')::uuid,
            target_user_id,
            (permission_config->>'permission_level')::permission_level,
            applied_by_user_id,
            false,
            expires_date,
            expires_date IS NOT NULL
        )
        ON CONFLICT (resource_type, resource_id, user_id) 
        DO UPDATE SET
            permission_level = EXCLUDED.permission_level,
            granted_by = EXCLUDED.granted_by,
            expires_at = EXCLUDED.expires_at,
            auto_revoke_enabled = EXCLUDED.auto_revoke_enabled,
            revoked_at = NULL,
            revoked_by = NULL;
    END LOOP;
    
    -- Update template usage
    UPDATE permission_templates 
    SET 
        usage_count = usage_count + 1,
        last_used_at = now(),
        updated_at = now()
    WHERE id = template_id;
    
    -- Log the template application
    INSERT INTO team_activity_log (team_id, actor_id, action_type, target_user_id, metadata)
    VALUES (
        template_record.team_id,
        applied_by_user_id,
        'permission_template_applied',
        target_user_id,
        jsonb_build_object(
            'template_id', template_id,
            'template_name', template_record.name,
            'permissions_count', jsonb_array_length(template_record.template_permissions)
        )
    );
END;
$$ LANGUAGE plpgsql;

-- =================================================================================
-- Triggers and Automation
-- =================================================================================

-- Trigger to update timestamps
CREATE TRIGGER update_access_requests_updated_at 
    BEFORE UPDATE ON access_requests 
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_permission_templates_updated_at 
    BEFORE UPDATE ON permission_templates 
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

-- =================================================================================
-- Comments
-- =================================================================================

COMMENT ON TABLE access_requests IS 'Self-service access requests for team resources';
COMMENT ON TABLE permission_templates IS 'Reusable permission templates for bulk user management';
COMMENT ON TABLE team_activity_log IS 'Enhanced audit trail for team permission activities';
COMMENT ON COLUMN resource_permissions.expires_at IS 'When this permission expires (NULL = permanent)';
COMMENT ON COLUMN resource_permissions.auto_revoke_enabled IS 'Whether to automatically revoke when expired';

